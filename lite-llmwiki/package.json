{
  "name": "lite-llmwiki",
  "version": "0.1.0",
  "description": "DeepSeek-native terminal knowledge workbench — ingest markdown, compile wiki, query graph",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "bin": {
    "llmwiki": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "ingest": "tsx src/cli/index.ts ingest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tobilu/qmd": "^2.5.3",
    "commander": "^13.0.0",
    "ink": "^7.0.4",
    "ink-text-input": "^6.0.0",
    "openai": "^6.39.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.6",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.15",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT"
}
